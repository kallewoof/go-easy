{
  "name": "go-easy",
  "version": "0.1.0",
  "description": "Google APIs made easy — Gmail, Drive, Calendar for AI agents and humans",
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./gmail": "./dist/gmail/index.js",
    "./drive": "./dist/drive/index.js",
    "./calendar": "./dist/calendar/index.js",
    "./auth": "./dist/auth.js"
  },
  "bin": {
    "go-gmail": "./dist/bin/gmail.js",
    "go-drive": "./dist/bin/drive.js",
    "go-calendar": "./dist/bin/calendar.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "google",
    "gmail",
    "drive",
    "calendar",
    "api",
    "ai-agent"
  ],
  "author": "Marc Fargas",
  "license": "MIT",
  "dependencies": {
    "googleapis": "^144.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
